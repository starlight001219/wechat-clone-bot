# 微信机器人配置
# 复制此文件为 .env 并填写你的配置

# ===== Claude API 配置 (必填) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxx
# 可选: 使用 OpenAI 兼容 API 替代 (如设置此项则优先使用)
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ===== 目标人设 =====
# 要模仿的微信好友昵称（用于筛选聊天记录分析）
TARGET_NAME=她的昵称
# 机器人自己的微信ID (WeChatFerry 会自动获取)
# BOT_WXID=

# ===== AI 参数 =====
AI_MODEL=claude-sonnet-4-20250506
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=500

# ===== 语音功能 =====
# edge-tts 语音: zh-CN-XiaoxiaoNeural, zh-CN-XiaoyiNeural, zh-CN-YunxiNeural
TTS_VOICE=zh-CN-XiaoxiaoNeural
# 语音回复开关 (true/false)
TTS_ENABLED=true
# 语音保存路径
TTS_OUTPUT_DIR=./voice_cache

# ===== 回复设置 =====
# 回复触发方式: keyword(关键词) / all(全部回复) / whitelist(白名单)
REPLY_MODE=all
# 白名单好友列表 (逗号分隔)
WHITELIST_FRIENDS=
# 回复延迟(秒)，模拟真人
REPLY_DELAY_MIN=1
REPLY_DELAY_MAX=5

# ===== 聊天记录 =====
# 导出的聊天记录JSON路径(用于训练语气)
CHAT_HISTORY_FILE=./chat_history.json
# 自动回复最大上下文轮数
MAX_CONTEXT_ROUNDS=20

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_FILE=./bot.log
