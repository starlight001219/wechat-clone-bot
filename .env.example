# LLM API 配置 (二选一)

# 选项 A: 本地模型（需要先训练+启动推理服务）
# USE_LOCAL_MODEL=true
# LOCAL_MODEL_URL=http://127.0.0.1:8000

# 选项 B: 远程 API (DeepSeek / OpenAI 兼容)
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 可选：Claude API
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 被模仿人的名字（用于 system prompt）
TARGET_NAME=朋友

# 机器人监听目标联系人（留空=监听所有会话）
TARGET_WXID=

# TTS 语音合成（基于 Edge-TTS，免费）
# 设为 true 后，每次回复会自动生成 .mp3 音频文件
TTS_ENABLED=false
# 可选: xiaoxiao(女声默认), yunyang(男声), xiaoyi(活泼女声), yunxi(活泼男声)
TTS_VOICE=xiaoxiao

# 日志级别
LOG_LEVEL=INFO
